# Copy this file to .env and replace values with your own Supabase project settings.

VITE_SUPABASE_URL=https://<your-project-ref>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=<your-public-anon-key>
VITE_SUPABASE_PROJECT_ID=<your-project-ref>

# Optional server-side key for seeding data locally.
# SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>
# Optional database password for CLI migrations.
# SUPABASE_DB_PASSWORD=<your-db-password>

# If you use server-side Supabase operations, also set these values:
# SUPABASE_URL=https://<your-project-ref>.supabase.co
# SUPABASE_PUBLISHABLE_KEY=<your-public-anon-key>
